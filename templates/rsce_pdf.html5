<?php
use Contao\FilesModel;

$fileModel = \Contao\FilesModel::findByUuid($this->file);
$pdfPath = $fileModel ? $fileModel->path : '';
?>


<?php if ($pdfPath): ?>
<div class="pdf-reader">
    <object
            data="<?= htmlspecialchars($pdfPath) ?>"
            type="application/pdf"
    >
        <p class="pdf-fallback">
            nscheinend ist kein PDF-Viewer in Ihrem Browser verfügbar.
            <a href="<?= htmlspecialchars($pdfPath) ?>" download>PDF herunterladen</a>
        </p>
    </object>
</div>

<div class="mobile-only pdf-reader-mobile">
    <a href="<?= htmlspecialchars($pdfPath) ?>" target="_blank">
        PDF herunterladen
    </a>
</div>
<?php endif; ?>