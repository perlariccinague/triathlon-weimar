<div class="slider-container <?= htmlspecialchars($this->cssID) ?>">
    <div class="slides">
        <?php foreach ($this->slide as $key => $slide): ?>
        <?php if ($slide->image && ($image = \Contao\FilesModel::findByUuid($slide->image))): ?>
        <div class="slide">
            <img src="<?= $image->path ?>" alt="Slide <?= $key + 1 ?>">
        </div>
        <?php endif; ?>
        <?php endforeach; ?>
    </div>
    <div class="dots"></div>
</div>